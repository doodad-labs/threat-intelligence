{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "ransomware-incident"
    },
    "title": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "victim": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "sector": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "extortion": {
      "type": "object",
      "properties": {
        "data_size_bytes": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "claimed_data_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "description"
      ],
      "additionalProperties": false
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "source"
        ],
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "press",
              "feed"
            ]
          }
        },
        "required": [
          "url",
          "source",
          "type"
        ],
        "additionalProperties": false
      }
    },
    "actor": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "n/a",
            "low",
            "medium",
            "high"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "confidence"
      ],
      "additionalProperties": false
    },
    "timeline": {
      "type": "object",
      "properties": {
        "attackedDate": {
          "type": "string"
        },
        "disclosedDate": {
          "type": "string"
        }
      },
      "required": [
        "disclosedDate"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "type",
    "title",
    "confidence",
    "victim",
    "extortion",
    "screenshots",
    "sources",
    "actor",
    "timeline"
  ],
  "additionalProperties": false,
  "definitions": {}
}