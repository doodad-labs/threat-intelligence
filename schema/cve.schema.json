{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Canonical schema URL describing this document shape."
    },
    "id": {
      "type": "string",
      "description": "CVE identifier, for example `CVE-2026-12345`."
    },
    "type": {
      "type": "string",
      "enum": [
        "cve",
        "nvd-cve"
      ],
      "description": "Record family emitted by the pipeline."
    },
    "status": {
      "type": "string",
      "description": "Upstream vulnerability lifecycle status."
    },
    "kev": {
      "type": "boolean",
      "description": "Whether the CVE appears in CISA's Known Exploited Vulnerabilities list."
    },
    "epss": {
      "type": "number",
      "description": "EPSS probability when supplied by an enrichment source."
    },
    "description": {
      "type": "string",
      "description": "Preferred human-readable vulnerability summary."
    },
    "metrics": {
      "type": "object",
      "properties": {
        "cvssV40": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Secondary",
                  "Primary"
                ]
              },
              "cvssData": {
                "type": "object",
                "properties": {
                  "version": {
                    "type": "string"
                  },
                  "vectorString": {
                    "type": "string"
                  },
                  "baseScore": {
                    "type": "number"
                  },
                  "baseSeverity": {
                    "type": "string",
                    "enum": [
                      "HIGH",
                      "MEDIUM",
                      "LOW",
                      "NONE"
                    ]
                  },
                  "attackVector": {
                    "type": "string"
                  },
                  "attackComplexity": {
                    "type": "string"
                  },
                  "attackRequirements": {
                    "type": "string"
                  },
                  "privilegesRequired": {
                    "type": "string"
                  },
                  "userInteraction": {
                    "type": "string"
                  },
                  "vulnConfidentialityImpact": {
                    "type": "string"
                  },
                  "vulnIntegrityImpact": {
                    "type": "string"
                  },
                  "vulnAvailabilityImpact": {
                    "type": "string"
                  },
                  "subConfidentialityImpact": {
                    "type": "string"
                  },
                  "subIntegrityImpact": {
                    "type": "string"
                  },
                  "subAvailabilityImpact": {
                    "type": "string"
                  },
                  "exploitMaturity": {
                    "type": "string"
                  },
                  "confidentialityRequirement": {
                    "type": "string"
                  },
                  "integrityRequirement": {
                    "type": "string"
                  },
                  "availabilityRequirement": {
                    "type": "string"
                  },
                  "modifiedAttackVector": {
                    "type": "string"
                  },
                  "modifiedAttackComplexity": {
                    "type": "string"
                  },
                  "modifiedAttackRequirements": {
                    "type": "string"
                  },
                  "modifiedPrivilegesRequired": {
                    "type": "string"
                  },
                  "modifiedUserInteraction": {
                    "type": "string"
                  },
                  "modifiedVulnConfidentialityImpact": {
                    "type": "string"
                  },
                  "modifiedVulnIntegrityImpact": {
                    "type": "string"
                  },
                  "modifiedVulnAvailabilityImpact": {
                    "type": "string"
                  },
                  "modifiedSubConfidentialityImpact": {
                    "type": "string"
                  },
                  "modifiedSubIntegrityImpact": {
                    "type": "string"
                  },
                  "modifiedSubAvailabilityImpact": {
                    "type": "string"
                  },
                  "Safety": {
                    "type": "string"
                  },
                  "Automatable": {
                    "type": "string"
                  },
                  "Recovery": {
                    "type": "string"
                  },
                  "valueDensity": {
                    "type": "string"
                  },
                  "vulnerabilityResponseEffort": {
                    "type": "string"
                  },
                  "providerUrgency": {
                    "type": "string"
                  }
                },
                "required": [
                  "version",
                  "vectorString",
                  "baseScore",
                  "baseSeverity",
                  "attackVector",
                  "attackComplexity",
                  "attackRequirements",
                  "privilegesRequired",
                  "userInteraction",
                  "vulnConfidentialityImpact",
                  "vulnIntegrityImpact",
                  "vulnAvailabilityImpact",
                  "subConfidentialityImpact",
                  "subIntegrityImpact",
                  "subAvailabilityImpact",
                  "exploitMaturity",
                  "confidentialityRequirement",
                  "integrityRequirement",
                  "availabilityRequirement",
                  "modifiedAttackVector",
                  "modifiedAttackComplexity",
                  "modifiedAttackRequirements",
                  "modifiedPrivilegesRequired",
                  "modifiedUserInteraction",
                  "modifiedVulnConfidentialityImpact",
                  "modifiedVulnIntegrityImpact",
                  "modifiedVulnAvailabilityImpact",
                  "modifiedSubConfidentialityImpact",
                  "modifiedSubIntegrityImpact",
                  "modifiedSubAvailabilityImpact",
                  "Safety",
                  "Automatable",
                  "Recovery",
                  "valueDensity",
                  "vulnerabilityResponseEffort",
                  "providerUrgency"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "source",
              "type",
              "cvssData"
            ],
            "additionalProperties": false
          },
          "description": "CVSS v4 metric sets, usually from NVD."
        },
        "cvssV31": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Secondary",
                  "Primary"
                ]
              },
              "cvssData": {
                "type": "object",
                "properties": {
                  "version": {
                    "type": "string"
                  },
                  "vectorString": {
                    "type": "string"
                  },
                  "baseScore": {
                    "type": "number"
                  },
                  "baseSeverity": {
                    "type": "string",
                    "enum": [
                      "HIGH",
                      "MEDIUM",
                      "LOW",
                      "NONE"
                    ]
                  },
                  "attackVector": {
                    "type": "string"
                  },
                  "attackComplexity": {
                    "type": "string"
                  },
                  "privilegesRequired": {
                    "type": "string"
                  },
                  "userInteraction": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "confidentialityImpact": {
                    "type": "string"
                  },
                  "integrityImpact": {
                    "type": "string"
                  },
                  "availabilityImpact": {
                    "type": "string"
                  }
                },
                "required": [
                  "version",
                  "vectorString",
                  "baseScore",
                  "baseSeverity",
                  "attackVector",
                  "attackComplexity",
                  "privilegesRequired",
                  "userInteraction",
                  "scope",
                  "confidentialityImpact",
                  "integrityImpact",
                  "availabilityImpact"
                ],
                "additionalProperties": false
              },
              "exploitabilityScore": {
                "type": "number"
              },
              "impactScore": {
                "type": "number"
              }
            },
            "required": [
              "source",
              "type",
              "cvssData",
              "exploitabilityScore",
              "impactScore"
            ],
            "additionalProperties": false
          },
          "description": "CVSS v3.1 metric sets."
        },
        "cvssV30": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Secondary",
                  "Primary"
                ]
              },
              "cvssData": {
                "type": "object",
                "properties": {
                  "version": {
                    "type": "string"
                  },
                  "vectorString": {
                    "type": "string"
                  },
                  "baseScore": {
                    "type": "number"
                  },
                  "baseSeverity": {
                    "type": "string",
                    "enum": [
                      "HIGH",
                      "MEDIUM",
                      "LOW",
                      "NONE"
                    ]
                  },
                  "attackVector": {
                    "type": "string"
                  },
                  "attackComplexity": {
                    "type": "string"
                  },
                  "privilegesRequired": {
                    "type": "string"
                  },
                  "userInteraction": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "confidentialityImpact": {
                    "type": "string"
                  },
                  "integrityImpact": {
                    "type": "string"
                  },
                  "availabilityImpact": {
                    "type": "string"
                  }
                },
                "required": [
                  "version",
                  "vectorString",
                  "baseScore",
                  "baseSeverity",
                  "attackVector",
                  "attackComplexity",
                  "privilegesRequired",
                  "userInteraction",
                  "scope",
                  "confidentialityImpact",
                  "integrityImpact",
                  "availabilityImpact"
                ],
                "additionalProperties": false
              },
              "exploitabilityScore": {
                "type": "number"
              },
              "impactScore": {
                "type": "number"
              }
            },
            "required": [
              "source",
              "type",
              "cvssData",
              "exploitabilityScore",
              "impactScore"
            ],
            "additionalProperties": false
          },
          "description": "CVSS v3.0 metric sets."
        },
        "cvssV2": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Secondary",
                  "Primary"
                ]
              },
              "cvssData": {
                "type": "object",
                "properties": {
                  "version": {
                    "type": "string"
                  },
                  "vectorString": {
                    "type": "string"
                  },
                  "baseScore": {
                    "type": "number"
                  },
                  "accessVector": {
                    "type": "string"
                  },
                  "accessComplexity": {
                    "type": "string",
                    "enum": [
                      "HIGH",
                      "MEDIUM",
                      "LOW",
                      "NONE"
                    ]
                  },
                  "authentication": {
                    "type": "string"
                  },
                  "confidentialityImpact": {
                    "type": "string"
                  },
                  "integrityImpact": {
                    "type": "string"
                  },
                  "availabilityImpact": {
                    "type": "string"
                  }
                },
                "required": [
                  "version",
                  "vectorString",
                  "baseScore",
                  "accessVector",
                  "accessComplexity",
                  "authentication",
                  "confidentialityImpact",
                  "integrityImpact",
                  "availabilityImpact"
                ],
                "additionalProperties": false
              },
              "baseSeverity": {
                "type": "string",
                "enum": [
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "NONE"
                ]
              },
              "exploitabilityScore": {
                "type": "number"
              },
              "impactScore": {
                "type": "number"
              },
              "acInsufInfo": {
                "type": "boolean"
              },
              "obtainAllPrivilege": {
                "type": "boolean"
              },
              "obtainUserPrivilege": {
                "type": "boolean"
              },
              "obtainOtherPrivilege": {
                "type": "boolean"
              },
              "userInteractionRequired": {
                "type": "boolean"
              }
            },
            "required": [
              "source",
              "type",
              "cvssData",
              "baseSeverity",
              "exploitabilityScore",
              "impactScore",
              "acInsufInfo",
              "obtainAllPrivilege",
              "obtainUserPrivilege",
              "obtainOtherPrivilege",
              "userInteractionRequired"
            ],
            "additionalProperties": false
          },
          "description": "Legacy CVSS v2 metric sets retained for older disclosures."
        }
      },
      "additionalProperties": false,
      "description": "Normalized scoring data copied from NVD metrics."
    },
    "requiredAction": {
      "type": "string",
      "description": "Vendor remediation guidance, typically sourced from CISA KEV."
    },
    "cwes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Normalized CWE identifiers attached to the record."
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lang": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              },
              "required": [
                "lang",
                "value"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "source",
          "type",
          "description"
        ],
        "additionalProperties": false
      },
      "description": "Free-form weakness descriptions that accompany the normalized CWE codes."
    },
    "exploits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "exploit": {
            "type": "string",
            "description": "Relative output path to the stored exploit artifact."
          },
          "author": {
            "type": "string",
            "description": "Author credited by the upstream exploit source."
          },
          "description": {
            "type": "string",
            "description": "Human-readable exploit title or summary."
          },
          "type": {
            "type": "string",
            "description": "Exploit category from the upstream source."
          },
          "platform": {
            "type": "string",
            "description": "Optional platform or target family."
          },
          "verified": {
            "type": "boolean",
            "description": "Whether the exploit source marked the entry as verified."
          },
          "screenshotUrl": {
            "type": "string",
            "description": "Screenshot preview URL when available."
          },
          "applicationUrl": {
            "type": "string",
            "description": "Optional vendor or application landing page."
          },
          "source": {
            "type": "string",
            "description": "Canonical upstream source URL."
          },
          "publishedDate": {
            "type": "string",
            "description": "Publication date reported by the exploit source."
          }
        },
        "required": [
          "exploit",
          "author",
          "type",
          "verified",
          "source",
          "publishedDate"
        ],
        "additionalProperties": false
      },
      "description": "Local or remote exploit artifacts associated with the CVE."
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Canonical normalized URL."
          },
          "source": {
            "type": "string",
            "description": "Human-readable source label."
          },
          "type": {
            "type": "string",
            "enum": [
              "press",
              "feed"
            ],
            "description": "Whether the URL came from a feed or editorial source."
          }
        },
        "required": [
          "url",
          "source",
          "type"
        ],
        "additionalProperties": false
      },
      "description": "References used as provenance and supporting evidence for the CVE."
    },
    "cpes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional CPE identifiers collected during enrichment."
    },
    "affectedProducts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "vendor": {
            "type": "string",
            "description": "Normalized vendor or project identifier."
          },
          "product": {
            "type": "string",
            "description": "Product name as emitted in the normalized record."
          },
          "ecosystem": {
            "type": "string",
            "description": "Package ecosystem, such as npm or PyPI, when known."
          },
          "platform": {
            "type": "string",
            "description": "Platform family when the product is platform-specific."
          },
          "packageType": {
            "type": "string",
            "description": "Package artifact type when the product is extensible content."
          },
          "repositoryUrl": {
            "type": "string",
            "description": "Canonical source repository URL."
          },
          "packageUrl": {
            "type": "string",
            "description": "Package registry URL."
          },
          "url": {
            "type": "string",
            "description": "Best general-purpose product URL when no stronger URL exists."
          },
          "affectedVersions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "versionType": {
                  "type": "string",
                  "enum": [
                    "semver",
                    "pep440",
                    "generic"
                  ],
                  "description": "Version comparison scheme used for the range."
                },
                "introduced": {
                  "type": "string",
                  "description": "Earliest introduced version when known."
                },
                "version": {
                  "type": "string",
                  "description": "Exact vulnerable version when the advisory names a single release."
                },
                "lessThan": {
                  "type": "string",
                  "description": "Exclusive upper bound."
                },
                "lessThanOrEqual": {
                  "type": "string",
                  "description": "Inclusive upper bound."
                },
                "greaterThan": {
                  "type": "string",
                  "description": "Exclusive lower bound."
                },
                "greaterThanOrEqual": {
                  "type": "string",
                  "description": "Inclusive lower bound."
                },
                "raw": {
                  "type": "string",
                  "description": "Raw advisory text used to infer this range."
                }
              },
              "additionalProperties": false
            },
            "description": "Version ranges believed to be affected by the vulnerability."
          },
          "fixedVersions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Known fixed versions gathered during enrichment."
          },
          "evidence": {
            "type": "object",
            "properties": {
              "descriptionMatches": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Relevant snippets extracted from the CVE description."
              },
              "referenceUrls": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Supporting reference URLs."
              }
            },
            "additionalProperties": false,
            "description": "Signals used to justify the affected-product inference."
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "description": "Confidence score for the inferred product match."
          }
        },
        "required": [
          "product"
        ],
        "additionalProperties": false
      },
      "description": "Best-effort product metadata inferred from references and vendor advisories."
    },
    "timeline": {
      "type": "object",
      "properties": {
        "publishedDate": {
          "type": "string",
          "description": "Original publication timestamp for the CVE."
        },
        "lastModifiedDate": {
          "type": "string",
          "description": "Timestamp when this normalized record was last written."
        }
      },
      "required": [
        "publishedDate",
        "lastModifiedDate"
      ],
      "additionalProperties": false,
      "description": "Key timestamps associated with publication and local processing."
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "type",
    "status",
    "metrics",
    "sources",
    "timeline"
  ],
  "additionalProperties": false,
  "description": "Canonical CVE record emitted by the aggregation pipeline.\n\nThe shape mirrors the JSON documents written to `out/data/cve` and later consumed by downstream indexing and publication steps.",
  "definitions": {}
}